{#
/**
 * @file
 * Default theme implementation to display a paragraph.
 *
 * Available variables:
 * - paragraph: Full paragraph entity.
 *   Only method names starting with "get", "has", or "is" and a few common
 *   methods such as "id", "label", and "bundle" are available. For example:
 *   - paragraph.getCreatedTime() will return the paragraph creation timestamp.
 *   - paragraph.id(): The paragraph ID.
 *   - paragraph.bundle(): The type of the paragraph, for example, "image" or "text".
 *   - paragraph.getOwnerId(): The user ID of the paragraph author.
 *   See Drupal\paragraphs\Entity\Paragraph for a full list of public properties
 *   and methods for the paragraph object.
 * - content: All paragraph items. Use {{ content }} to print them all,
 *   or print a subset such as {{ content.field_example }}. Use
 *   {{ content|without('field_example') }} to temporarily suppress the printing
 *   of a given child element.
 * - attributes: HTML attributes for the containing element.
 *   The attributes.class element may contain one or more of the following
 *   classes:
 *   - paragraphs: The current template type (also known as a "theming hook").
 *   - paragraphs--type-[type]: The current paragraphs type. For example, if the paragraph is an
 *     "Image" it would result in "paragraphs--type--image". Note that the machine
 *     name will often be in a short form of the human readable label.
 *   - paragraphs--view-mode--[view_mode]: The View Mode of the paragraph; for example, a
 *     preview would result in: "paragraphs--view-mode--preview", and
 *     default: "paragraphs--view-mode--default".
 * - view_mode: View mode; for example, "preview" or "full".
 * - logged_in: Flag for authenticated user status. Will be true when the
 *   current user is a logged-in member.
 * - is_admin: Flag for admin user status. Will be true when the current user
 *   is an administrator.
 *
 * @see template_preprocess_paragraph()
 *
 * @ingroup themeable
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished'
  ]
%}
{% if paragraph.field_width.value == "small" %}
    {% set width = 'xl:max-w-75' %}
{% elseif paragraph.field_width.value == "medium"%}
    {% set width = 'xl:max-w-95' %}
{% elseif paragraph.field_width.value == "large"%}
    {% set width = 'xl:max-w-119' %}
{% endif %}

{% if paragraph.field_heading_width.value == "small" %}
    {% set headingWidth = 'xl:w-3/12' %}
{% elseif paragraph.field_heading_width.value == "medium"%}
    {% set headingWidth = 'xl:w-6/12' %}
{% elseif paragraph.field_heading_width.value == "large"%}
    {% set headingWidth = 'lg:w-8/12' %}
{% endif %}

{% if paragraph.field_image_alt_text.value is not empty %}
  {% set alt_text =  paragraph.field_image_alt_text.value  %}
{% else %}
  {% set alt_text =  paragraph.field_image.entity.field_media_image.alt  %}
{% endif %}

{% if paragraph.field_title_tags.value is not empty %}
    {% set title_heading =  paragraph.field_title_tags.value  %}
{% else %}
    {% set title_heading =  'h1'  %}
{% endif %}

{% if paragraph.field_title_size_weight.value is not empty %}
    {% set heading_class =  paragraph.field_title_size_weight.value  %}
{% else %}
    {% set heading_class =  'font-medium md:font-semibold'  %}
{% endif %}


{% block paragraph %}
    {% block content %}
        {% if paragraph.field_image.entity.field_media_image.entity.uri.value is not empty %}
            <section
                class="bg-gradient-{{ paragraph.field_background_color.value|raw }} md:min-h-225 overflow-hidden py-0 relative top-banner-section">
                <div class="container mx-auto md:pb-25">
                    <div class="flex pt-22"> {# max-md:px-7.5 #}
                        <div class="max-xl:w-full {{ headingWidth }}"> {# max-md:pr-17 #}
                            <{{ title_heading }} class="{{ heading_class }}">{{ paragraph.field_title.value|raw }}</{{ title_heading }}>
                        </div>
                    </div>
                    <div class="flex flex-col xl:flex-row items-start xl:items-end justify-between gap-5">
                        <div class="w-full {{ width }} flex flex-col gap-2.5"> {# max-md:px-7.5 #}
                            <img src="/themes/custom/quitpath/assets/images/arrow-down.svg"
                                class="max-xl:pb-[41px] max-xl:pt-2.5 xl:py-15 w-6" alt="arrow">
                            {{ paragraph.field_description.value|raw }}
                        </div>
                        <div class="w-full">
                            <img src="{{ file_url(paragraph.field_image.entity.field_media_image.entity.uri.value) }}" class="top-banner-img max-xl:mt-10 xl:absolute {{ paragraph.field_image_vertical_alignment.value|raw }} max-h-200" alt="{{ alt_text }}">
                        </div>
                    </div>
                </div>
            </section>
        {% else %}
            <section class="bg-{{ paragraph.field_background_color.value|raw }} top-banner-section">
                <div class="mx-auto container">
                    <div class="space-y-7.5 font-normal text-display-xs content">
                        <{{ title_heading }} class="{{ heading_class }}">{{ paragraph.field_title.value|raw }}</{{ title_heading }}>
                        {{ paragraph.field_description.value|raw }}
                    </div>
                </div>
            </section>
            
        {% endif %}

    {% endblock %}
{% endblock paragraph %}
 
 
