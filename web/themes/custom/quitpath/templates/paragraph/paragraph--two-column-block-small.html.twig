{#
/**
 * @file
 * Default theme implementation to display a paragraph.
 *
 * Available variables:
 * - paragraph: Full paragraph entity.
 *   Only method names starting with "get", "has", or "is" and a few common
 *   methods such as "id", "label", and "bundle" are available. For example:
 *   - paragraph.getCreatedTime() will return the paragraph creation timestamp.
 *   - paragraph.id(): The paragraph ID.
 *   - paragraph.bundle(): The type of the paragraph, for example, "image" or "text".
 *   - paragraph.getOwnerId(): The user ID of the paragraph author.
 *   See Drupal\paragraphs\Entity\Paragraph for a full list of public properties
 *   and methods for the paragraph object.
 * - content: All paragraph items. Use {{ content }} to print them all,
 *   or print a subset such as {{ content.field_example }}. Use
 *   {{ content|without('field_example') }} to temporarily suppress the printing
 *   of a given child element.
 * - attributes: HTML attributes for the containing element.
 *   The attributes.class element may contain one or more of the following
 *   classes:
 *   - paragraphs: The current template type (also known as a "theming hook").
 *   - paragraphs--type-[type]: The current paragraphs type. For example, if the paragraph is an
 *     "Image" it would result in "paragraphs--type--image". Note that the machine
 *     name will often be in a short form of the human readable label.
 *   - paragraphs--view-mode--[view_mode]: The View Mode of the paragraph; for example, a
 *     preview would result in: "paragraphs--view-mode--preview", and
 *     default: "paragraphs--view-mode--default".
 * - view_mode: View mode; for example, "preview" or "full".
 * - logged_in: Flag for authenticated user status. Will be true when the
 *   current user is a logged-in member.
 * - is_admin: Flag for admin user status. Will be true when the current user
 *   is an administrator.
 *
 * @see template_preprocess_paragraph()
 *
 * @ingroup themeable
 */
#}

{% if paragraph.field_size.value == '25_75' %}
    {%  set first_class = 'lg:w-3/12' %}
    {%  set second_class = 'lg:w-9/12' %}
{% endif %}
{% if paragraph.field_size.value == '33_66' %}
    {%  set first_class = 'lg:w-4/12' %}
    {%  set second_class = 'lg:w-8/12' %}
{% endif %}
{% if paragraph.field_size.value == '40_60' %}
    {%  set first_class = 'lg:w-5/12' %}
    {%  set second_class = 'lg:w-7/12' %}
{% endif %}
{% if paragraph.field_size.value == '50_50' %}
    {%  set first_class = 'lg:w-1/2' %}
    {%  set second_class = 'lg:w-1/2' %}
{% endif %}
{% if paragraph.field_size.value == '75_25' %}
    {%  set first_class = 'lg:w-9/12' %}
    {%  set second_class = 'lg:w-3/12' %}
{% endif %}
{% if paragraph.field_size.value == '66_33' %}
    {%  set first_class = 'lg:w-8/12' %}
    {%  set second_class = 'lg:w-4/12' %}
{% endif %}
{% if paragraph.field_size.value == '60_40' %}
    {%  set first_class = 'lg:w-7/12' %}
    {%  set second_class = 'lg:w-5/12' %}
{% endif %}

{% if paragraph.field_gap.value == 'small' %}
    {%  set gap = 'gap-7.5 lg:gap-10' %}
{% endif %}
{% if paragraph.field_gap.value == 'medium' %}
    {%  set gap = 'gap-7.5 lg:gap-20' %}
{% endif %}
{% if paragraph.field_gap.value == 'large' %}
    {%  set gap = 'gap-7.5 lg:gap-30' %}
{% endif %}

{#{% if paragraph.field_heading_size.value == 'h2' %}#}
{#    {%  set heading = 'h2' %}#}
{#    {%  set heading_class = 'text-display-sm font-medium' %}#}
{#{% elseif paragraph.field_heading_size.value == 'h2_large' %}#}
{#    {%  set heading = 'h2' %}#}
{#    {%  set heading_class = 'font-medium' %}#}
{#{% elseif paragraph.field_heading_size.value == 'h1' %}#}
{#    {%  set heading = 'h1' %}#}
{#    {%  set heading_class = 'text-display-xl font-medium' %}#}
{#{% else %}#}
{#    {%  set heading = paragraph.field_heading_size.value %}#}
{#    {%  set heading_class = 'font-medium' %}#}
{#{% endif %}#}

{% if paragraph.field_button_color.value == 'yellow' %}
    {%  set button_color = 'btn btn-yellow' %}
{% elseif paragraph.field_button_color.value == 'blue' %}
    {%  set button_color = ' btn btn-blue' %}
{% elseif paragraph.field_button_color.value == 'red' %}
    {%  set button_color = 'btn btn-red' %}
{% elseif paragraph.field_button_color.value == 'green' %}
    {%  set button_color = 'btn btn-green' %}
{% elseif paragraph.field_button_color.value == 'light_blue' %}
    {%  set button_color = ' btn btn-light-blue' %}
{% elseif paragraph.field_button_color.value == 'dark_red' %}
    {%  set button_color = 'btn btn-dark-red' %}
{% elseif paragraph.field_button_color.value == 'dark_blue' %}
    {%  set button_color = ' btn btn-dark-blue' %}
{% elseif paragraph.field_button_color.value == 'dark_green' %}
    {%  set button_color = 'btn btn-dark-green' %}
{% elseif paragraph.field_button_color.value == 'dark_yellow' %}
    {%  set button_color = 'btn btn-dark-yellow' %}
{% elseif paragraph.field_button_color.value == 'dark_light_blue' %}
    {%  set button_color = 'btn btn-dark-light-blue' %}
{% endif %}

{% if paragraph.field_image_alt_text.value is not empty %}
  {% set alt_text =  paragraph.field_image_alt_text.value  %}
{% else %}
  {% set alt_text =  paragraph.field_image.entity.field_media_image.alt  %}
{% endif %}



{% if paragraph.field_heading.value is not empty %}
    {% set title_heading =  paragraph.field_heading.value  %}
{% else %}
    {% set title_heading =  'h2'  %}
{% endif %}

{% if paragraph.field_size_weight.value is not empty %}
    {% set heading_class =  paragraph.field_size_weight.value  %}
{% else %}
    {% set heading_class =  'font-medium'  %}
{% endif %}


{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,

    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished'
  ]
%}
{% block paragraph %}
    {% block content %}
        
        <section class="two-col-section {% if paragraph.field_background_color.value is not empty %} bg-{{ paragraph.field_background_color.value|raw }} {% endif %}" id="pid-{{ paragraph.id() }}">
            <div class="container mx-auto">
                <div class="flex max-lg:flex-col-reverse {% if paragraph.id() != 388 %} items-center {% endif %} {{ gap }}">
                    {% if paragraph.field_image_position.value == "right" %}
                        <div class="w-full {{ first_class }} text-gray-900 space-y-2.5 lg:space-y-7.5">
                            {% if paragraph.field_title.value is not empty %}<{{ title_heading }} class="{{ heading_class }}">{{ paragraph.field_title.value|raw }}</{{ title_heading }}>{% endif %}
                            {{ paragraph.field_description.value|raw }}
                            {% if paragraph.field_link.title is not empty %}<a href="{{ paragraph.field_link.get(0).getUrl().toString() }}" class="inline-block py-2.5 px-4.5 max-md:mt-[27px] rounded-[10px] {{ button_color }} text-white text-md font-semibold">{{ paragraph.field_link.title }}</a>{% endif %}
                            {% if paragraph.id() == 388 %} {{ drupal_form('Drupal\\contact_form\\Form\\CustomContactForm') }} {% endif %}
                        </div>
                        <div class="w-full {{ second_class }} md:min-w-95">
                            <img src="{{ file_url(paragraph.field_image.entity.field_media_image.entity.uri.value) }}" class="rounded-[10px] w-full max-md:!h-auto" alt="{{ alt_text }}" {% if paragraph.field_image_height.value is not empty %} style="height:{{ paragraph.field_image_height.value }}px"{% endif %}>
                        </div>
                        
                    {% else %}
                        <div class="w-full {{ first_class }} md:min-w-95">
                            <img src="{{ file_url(paragraph.field_image.entity.field_media_image.entity.uri.value) }}" class="rounded-[10px] w-full max-md:!h-auto" alt="{{ alt_text }}" {% if paragraph.field_image_height.value is not empty %} style="height:{{ paragraph.field_image_height.value }}px"{% endif %}>
                        </div>
                        <div class="w-full {{ second_class }} text-gray-900 space-y-2.5 lg:space-y-7.5">
                            {% if paragraph.field_title.value is not empty %}<{{ title_heading }} class="{{ heading_class }}">{{ paragraph.field_title.value|raw }}</{{ title_heading }}>{% endif %}
                            {{ paragraph.field_description.value|raw }}
                            <div class="flex gap-5 xl:gap-10 flex-wrap text-md font-semibold max-md:mt-[27px]">
                            {% if paragraph.field_link.title is not empty %}
                                <a href="{{ paragraph.field_link.get(0).getUrl().toString() }}" class="py-2.5 px-4.5 rounded-[10px] {{ button_color }} text-white">{{ paragraph.field_link.title }}</a>
                            {% endif %}
                            {% if paragraph.field_button_link_2.title is not empty %}
                                <a href="{{ paragraph.field_button_link_2.get(0).getUrl().toString() }}" class="py-2.5 px-4.5 rounded-[10px] {{ button_color }} text-white">{{ paragraph.field_button_link_2.title }}</a>
                            {% endif %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </section>

    {% endblock %}
{% endblock paragraph %}
 
 
