{
    "name": "ytgov/lagoon-quitpath-ca",
    "description": "Yukon Government - HSS - Get help to quit smoking and vaping.",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "vcs",
            "url": "git@github.com:ytgov/lagoon-boutique-base-image.git"
        }
    ],
    "require": {
        "ytgov/lagoon-boutique-base-image": "dev-prod",
        "drupal/simple_menu_icons": "^3.1",
        "drupal/dependent_fields": "^1.0",
        "drupal/conditional_fields": "^4.0@alpha",
        "drupal/sitemap": "^2.0",
        "drupal/simple_sitemap": "^4.2",
        "drupal/shield": "^1.8",
        "drupal/redirect_after_login": "^3.0",
        "drupal/editoria11y": "^2.2",
        "drupal/smtp": "^1.4",
        "drupal/mailsystem": "^4.5",
        "drupal/external_link_popup": "^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": ["type:drupal-library"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/contrib/{$name}": ["type:drupal-drush"]
        },
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            },
            "excludes": [
                "sites/development.services.yml",
                "sites/example.settings.local.php"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "drupal/core-project-message": false,
            "drupal/core-composer-scaffold": true,
            "cweagans/composer-patches": true,
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
